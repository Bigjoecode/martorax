# MartoraX Admin — environment variables
# Copy to .env.local for local dev; set the same in Vercel Project Settings > Environment Variables.

# Public Supabase project (safe to expose — used for admin login auth)
NEXT_PUBLIC_SUPABASE_URL=https://wceitvgbwhnnvxkauphe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SECRET — server-side only. Supabase dashboard > Project Settings > API > service_role.
# Grants full DB access (bypasses RLS). NEVER expose to the browser. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of emails allowed into the admin. Only these accounts can sign in.
ADMIN_EMAILS=mejortechworld@gmail.com
